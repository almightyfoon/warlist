# Copy this file to .env and fill in the values before running docker compose.

# Database
DB_USER=warlist
DB_PASSWORD=changeme
DB_NAME=warlist
DB_ROOT_PASSWORD=changeme_root

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Application
APP_VERSION=dev

# Caddy / TLS
# DOMAIN is the hostname Caddy serves the app on. APEX_DOMAIN (optional) gets
# a permanent redirect to DOMAIN instead of serving content directly -- only
# set it if the apex domain's DNS actually points at this host.
DOMAIN=www.warlist.online
APEX_DOMAIN=warlist.online
CADDY_EMAIL=you@example.com
